# Copy these lines into your .env after creating a free cloud database.
# Recommended: Aiven free MySQL (no credit card) — https://console.aiven.io/signup

DB_CONNECTION=mysql
DB_HOST=YOUR-SERVICE.a.aivencloud.com
DB_PORT=12345
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=paste-password-from-aiven-console

# Download "CA certificate" from Aiven → your service → Overview → Connection info
# Save the file as: database/ssl/ca.pem
MYSQL_ATTR_SSL_CA=database/ssl/ca.pem

# Optional: full URL instead of separate vars (comment out lines above if you use this)
# DB_URL=mysql://avnadmin:PASSWORD@HOST:PORT/defaultdb?ssl-mode=REQUIRED

# ── Alternative: Supabase PostgreSQL (requires pdo_pgsql in PHP) ──
# DB_CONNECTION=pgsql
# DB_HOST=db.xxxxx.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=your-supabase-password
# DB_SSLMODE=require
