APP_NAME="Mini Games"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production (Render): see render.yaml and deploy/render-setup.txt
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://themaniak.online
# SESSION_DOMAIN=.themaniak.online

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite

# Cloud MySQL (Aiven): database/cloud-db-setup.txt
# DB_CONNECTION=mysql
# DB_HOST=
# DB_PORT=
# DB_DATABASE=defaultdb
# DB_USERNAME=avnadmin
# DB_PASSWORD=
# DB_SSL_RELAXED=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Google Analytics 4 — Measurement ID from analytics.google.com (e.g. G-XXXXXXXXXX)
GA_MEASUREMENT_ID=
